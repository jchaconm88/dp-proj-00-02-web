# ============================================================
# VARIABLES DE ENTORNO — Firebase
# ============================================================
# Copia este archivo a .env y rellena con los valores reales
# de Firebase Console > Configuración del proyecto > Tus apps
# ============================================================

# Firebase - copia a .env y rellena con los valores de tu proyecto en Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: usar emuladores locales durante desarrollo
# VITE_USE_FIREBASE_EMULATORS=true
