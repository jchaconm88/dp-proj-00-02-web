rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function isPlatformAdmin() {
      return isSignedIn()
        && request.auth.token.platformAdmin == true;
    }

    function tokenHasPermission(module, action) {
      return isSignedIn()
        && request.auth.token.permissionCodes is list
        && request.auth.token.permissionCodes.hasAny([
          "*",
          module,
          module + ":" + action,
          "*:" + module
        ]);
    }

    function canReadUsersCollection() {
      return isSignedIn()
        && (
          tokenHasPermission("user", "view")
          || isPlatformAdmin()
        );
    }

    /** Membership doc ID determinístico: `${companyId}_${uid}` */
    function companyUserId(companyId, uid) {
      return companyId + "_" + uid;
    }

    function isMember(companyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/company-users/$(companyUserId(companyId, myUid())))
        && get(/databases/$(database)/documents/company-users/$(companyUserId(companyId, myUid()))).data.status != "inactive";
    }

    /** Compatibilidad: sin accountId en doc o sin claim aún, o coinciden. */
    function legacyOrTokenAccountMatches() {
      return !('accountId' in resource.data)
        || resource.data.accountId == null
        || !('accountId' in request.auth.token)
        || request.auth.token.accountId == null
        || request.auth.token.accountId == resource.data.accountId;
    }

    function accountMatchesData(data) {
      return !('accountId' in data)
        || data.accountId == null
        || !('accountId' in request.auth.token)
        || request.auth.token.accountId == null
        || request.auth.token.accountId == data.accountId;
    }

    function effectiveCompanyId() {
      return request.method == "create"
        ? request.resource.data.companyId
        : resource.data.companyId;
    }

    function effectiveAccountMatches() {
      return request.method == "create"
        ? accountMatchesData(request.resource.data)
        : accountMatchesData(resource.data);
    }

    function canManageCompanyMembers(companyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/company-users/$(companyUserId(companyId, myUid())))
        && get(/databases/$(database)/documents/company-users/$(companyUserId(companyId, myUid()))).data.status != "inactive"
        && tokenHasPermission("user", "edit");
    }

    // Perfiles: colección `users` (alineado con ~/lib/auth-context).
    // Lectura también si el email del documento coincide con el token (perfiles legacy con docId != Auth UID).
    match /users/{userId} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == userId
          || (
            resource.data.email is string
            && request.auth.token.email != null
            && resource.data.email == request.auth.token.email
          )
          || canReadUsersCollection()
        );
      allow write: if isSignedIn()
        && (request.auth.uid == userId || isPlatformAdmin());
    }

    match /companies/{companyId} {
      allow read: if (isMember(companyId) || isPlatformAdmin()) && legacyOrTokenAccountMatches();
      allow write: if isPlatformAdmin();
    }

    match /accounts/{accountId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || !('accountId' in request.auth.token) || request.auth.token.accountId == null || request.auth.token.accountId == accountId);
      allow write: if isPlatformAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || !('accountId' in resource.data) || !('accountId' in request.auth.token) || request.auth.token.accountId == null || resource.data.accountId == request.auth.token.accountId);
      allow write: if isPlatformAdmin();
    }

    /** Catálogo SaaS (límites / features); distinto de trip-plans. */
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    /** Configuración dinámica del dashboard (métricas/tarjetas). */
    match /metric-definitions/{metricId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    match /dashboard-card-definitions/{cardId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    match /usage-months/{usageId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || !('accountId' in resource.data) || !('accountId' in request.auth.token) || request.auth.token.accountId == null || resource.data.accountId == request.auth.token.accountId);
      allow write: if isPlatformAdmin();
    }

    match /dashboard-snapshots/{snapshotId} {
      allow read: if isSignedIn() && (isPlatformAdmin() || !('accountId' in resource.data) || !('accountId' in request.auth.token) || request.auth.token.accountId == null || resource.data.accountId == request.auth.token.accountId);
      allow write: if false;
    }

    match /company-users/{membershipId} {
      allow read: if isSignedIn();
      allow create: if isPlatformAdmin()
        || (isSignedIn()
          && request.resource.data.companyId is string
          && request.resource.data.companyId.size() > 0
          && request.resource.data.userId is string
          && request.resource.data.userId.size() > 0
          && canManageCompanyMembers(request.resource.data.companyId));
      allow update: if isPlatformAdmin()
        || (isSignedIn()
          && resource.data.companyId == request.resource.data.companyId
          && request.resource.data.userId is string
          && request.resource.data.userId.size() > 0
          // Compatibilidad de transición: valida contra el ID del doc, no contra campo legacy.
          && membershipId == (resource.data.companyId + "_" + request.resource.data.userId)
          && canManageCompanyMembers(resource.data.companyId));
      allow delete: if isPlatformAdmin()
        || (isSignedIn() && canManageCompanyMembers(resource.data.companyId));
    }

    match /roles/{roleId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      allow create: if isSignedIn()
        && isMember(request.resource.data.companyId)
        && accountMatchesData(request.resource.data)
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0;
      allow update, delete: if isPlatformAdmin();
    }

    // --- Transporte (colecciones raíz en kebab-case donde aplica) ---
    match /trip-assignments/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /trip-charges/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /trip-costs/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }

    match /trips/{tripId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      allow create: if isSignedIn()
        && isMember(request.resource.data.companyId)
        && (
          !('accountId' in request.resource.data)
          || request.resource.data.accountId == null
          || !('accountId' in request.auth.token)
          || request.auth.token.accountId == null
          || request.auth.token.accountId == request.resource.data.accountId
        );
      allow update, delete: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      match /tripStops/{stopId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/trips/$(tripId)).data.companyId)
          && effectiveAccountMatches();
      }
    }

    match /settlements/{settlementId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
      match /items/{itemId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/settlements/$(settlementId)).data.companyId)
          && effectiveAccountMatches();
      }
    }

    match /transport-contracts/{contractId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
      match /transport-rate-rules/{ruleId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/transport-contracts/$(contractId)).data.companyId)
          && effectiveAccountMatches();
      }
    }

    match /transport-services/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }

    match /drivers/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /vehicles/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /trip-routes/{routeId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
      match /stops/{stopId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/trip-routes/$(routeId)).data.companyId)
          && effectiveAccountMatches();
      }
    }
    match /trip-plans/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
      match /locations/{locationId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/clients/$(clientId)).data.companyId)
          && effectiveAccountMatches();
      }
    }
    match /document-types/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /charge-types/{docId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      allow create: if isSignedIn()
        && isMember(request.resource.data.companyId)
        && (
          !('accountId' in request.resource.data)
          || request.resource.data.accountId == null
          || !('accountId' in request.auth.token)
          || request.auth.token.accountId == null
          || request.auth.token.accountId == request.resource.data.accountId
        );
      allow update, delete: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
    }

    match /orders/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }

    match /employees/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /positions/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /resources/{resourceId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
      match /resource-costs/{costId} {
        allow read, write: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/resources/$(resourceId)).data.companyId)
          && effectiveAccountMatches();
      }
    }

    match /sequences/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /counters/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }
    match /modules/{docId} {
      allow read, write: if isSignedIn() && isMember(effectiveCompanyId()) && effectiveAccountMatches();
    }

    match /report-definitions/{docId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      allow write: if isSignedIn()
        && isMember(request.resource.data.companyId)
        && accountMatchesData(request.resource.data)
        && (
          !('notifyEmails' in request.resource.data)
          || (
            request.resource.data.notifyEmails is list
            && request.resource.data.notifyEmails.size() <= 30
          )
        )
        && (
          !('exportTitleTemplate' in request.resource.data)
          || (
            request.resource.data.exportTitleTemplate is string
            && request.resource.data.exportTitleTemplate.size() > 0
            && request.resource.data.exportTitleTemplate.size() <= 300
          )
        )
        && (
          !('exportFileNameTemplate' in request.resource.data)
          || (
            request.resource.data.exportFileNameTemplate is string
            && request.resource.data.exportFileNameTemplate.size() > 0
            && request.resource.data.exportFileNameTemplate.size() <= 200
          )
        )
        && (
          !('notifyEmailSubjectTemplate' in request.resource.data)
          || request.resource.data.notifyEmailSubjectTemplate is string
        )
        && (
          !('notifyEmailBodyHtml' in request.resource.data)
          || request.resource.data.notifyEmailBodyHtml is string
        );
    }

    match /report-runs/{docId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId) && legacyOrTokenAccountMatches();
      allow write: if false;
    }
  }
}
