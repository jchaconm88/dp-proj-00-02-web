rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Perfiles: colección `users` (alineado con ~/lib/auth-context).
    match /users/{userId} {
      allow read, write: if isSignedIn()
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['admin']));
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['admin']);
    }

    // --- Transporte (colecciones raíz en kebab-case donde aplica) ---
    match /trip-assignments/{docId} {
      allow read, write: if isSignedIn();
    }
    match /trip-charges/{docId} {
      allow read, write: if isSignedIn();
    }
    match /trip-costs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /trips/{tripId} {
      allow read, write: if isSignedIn();
      match /tripStops/{stopId} {
        allow read, write: if isSignedIn();
      }
    }

    match /settlements/{settlementId} {
      allow read, write: if isSignedIn();
      match /items/{itemId} {
        allow read, write: if isSignedIn();
      }
    }

    match /transport-contracts/{contractId} {
      allow read, write: if isSignedIn();
      match /transport-rate-rules/{ruleId} {
        allow read, write: if isSignedIn();
      }
    }

    match /transport-services/{docId} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{docId} {
      allow read, write: if isSignedIn();
    }
    match /vehicles/{docId} {
      allow read, write: if isSignedIn();
    }
    match /routes/{routeId} {
      allow read, write: if isSignedIn();
      match /stops/{stopId} {
        allow read, write: if isSignedIn();
      }
    }
    match /plans/{docId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
      match /locations/{locationId} {
        allow read, write: if isSignedIn();
      }
    }
    match /document-types/{docId} {
      allow read, write: if isSignedIn();
    }

    match /orders/{docId} {
      allow read, write: if isSignedIn();
    }

    match /employees/{docId} {
      allow read, write: if isSignedIn();
    }
    match /positions/{docId} {
      allow read, write: if isSignedIn();
    }
    match /resources/{resourceId} {
      allow read, write: if isSignedIn();
      match /resourceCosts/{costId} {
        allow read, write: if isSignedIn();
      }
    }

    match /sequences/{docId} {
      allow read, write: if isSignedIn();
    }
    match /counters/{docId} {
      allow read, write: if isSignedIn();
    }
    match /modules/{docId} {
      allow read, write: if isSignedIn();
    }

    match /reportDefinitions/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && (
          !('notifyEmails' in request.resource.data)
          || (
            request.resource.data.notifyEmails is list
            && request.resource.data.notifyEmails.size() <= 30
          )
        )
        && (
          !('exportTitleTemplate' in request.resource.data)
          || (
            request.resource.data.exportTitleTemplate is string
            && request.resource.data.exportTitleTemplate.size() > 0
            && request.resource.data.exportTitleTemplate.size() <= 300
          )
        )
        && (
          !('exportFileNameTemplate' in request.resource.data)
          || (
            request.resource.data.exportFileNameTemplate is string
            && request.resource.data.exportFileNameTemplate.size() > 0
            && request.resource.data.exportFileNameTemplate.size() <= 200
          )
        )
        && (
          !('notifyEmailSubjectTemplate' in request.resource.data)
          || request.resource.data.notifyEmailSubjectTemplate is string
        )
        && (
          !('notifyEmailBodyHtml' in request.resource.data)
          || request.resource.data.notifyEmailBodyHtml is string
        );
    }

    match /reportRuns/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
