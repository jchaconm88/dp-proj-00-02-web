rules_version = '2';
// Ejemplo ilustrativo: NO sustituye firestore.rules del proyecto.
// Nombres de colección alineados con kebab-case (trip-plans, trip-routes, resource-costs, report-definitions, company-users, etc.).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn()
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['admin']));
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleIds.hasAny(['admin']);
    }

    match /company-users/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && membershipId == (request.resource.data.companyId + "_" + request.resource.data.userId);
    }

    match /trip-assignments/{docId} {
      allow read, write: if isSignedIn();
    }
    match /trip-charges/{docId} {
      allow read, write: if isSignedIn();
    }
    match /trip-costs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /trips/{tripId} {
      allow read, write: if isSignedIn();
      match /tripStops/{stopId} {
        allow read, write: if isSignedIn();
      }
    }

    match /settlements/{settlementId} {
      allow read, write: if isSignedIn();
      match /items/{itemId} {
        allow read, write: if isSignedIn();
      }
    }

    match /transport-contracts/{contractId} {
      allow read, write: if isSignedIn();
      match /transport-rate-rules/{ruleId} {
        allow read, write: if isSignedIn();
      }
    }

    match /transport-services/{docId} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{docId} {
      allow read, write: if isSignedIn();
    }
    match /vehicles/{docId} {
      allow read, write: if isSignedIn();
    }

    // Rutas de transporte (no confundir con colección SaaS `plans`).
    match /trip-routes/{routeId} {
      allow read, write: if isSignedIn();
      match /stops/{stopId} {
        allow read, write: if isSignedIn();
      }
    }

    match /trip-plans/{docId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
      match /locations/{locationId} {
        allow read, write: if isSignedIn();
      }
    }
    match /document-types/{docId} {
      allow read, write: if isSignedIn();
    }

    match /orders/{docId} {
      allow read, write: if isSignedIn();
    }

    match /employees/{docId} {
      allow read, write: if isSignedIn();
    }
    match /positions/{docId} {
      allow read, write: if isSignedIn();
    }
    match /resources/{resourceId} {
      allow read, write: if isSignedIn();
      match /resource-costs/{costId} {
        allow read, write: if isSignedIn();
      }
    }

    match /sequences/{docId} {
      allow read, write: if isSignedIn();
    }
    match /counters/{docId} {
      allow read, write: if isSignedIn();
    }
    match /modules/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
