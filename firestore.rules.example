rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Perfiles de usuario: solo el propio usuario o admins pueden leer/escribir
    match /profiles/{userId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == userId || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.roleIds.hasAny(['admin']));
    }
    // Roles: solo autenticados pueden leer; solo admin puede escribir
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.roleIds.hasAny(['admin']);
    }
  }
}
